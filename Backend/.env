# ─────────────────────────────────────────────
#  AI Startup Advisor — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=5000

# MongoDB — replace with your Atlas connection string or local URI
MONGO_URI=mongodb+srv://ecollect:rgVBfXe8YBlKSgQW@cluster0.hscnmg9.mongodb.net/aiadvisor?appName=Cluster0
# Atlas example:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ai-startup-advisor?retryWrites=true&w=majority

# JWT — use a long, random secret (e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000
